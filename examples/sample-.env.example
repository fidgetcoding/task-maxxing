# task-maxxing — environment variables
#
# Copy this file to `.env` at the root of your task-maxxing clone and fill
# in the values. NEVER commit `.env` (it is gitignored by default).
#
# ---------------------------------------------------------------------------
# Core: where your vault lives
# ---------------------------------------------------------------------------

# Absolute path to the directory inside your Obsidian vault that holds your
# task area files (TASKS-URGENT.md, TASKS-GENERAL.md, …). This is the dir the
# auto-commit daemon watches and that scripts/morgen-backfill.js reads.
VAULT_PATH=/absolute/path/to/your-vault/08-Tasks

# Alias used by src/auto-commit.js. Usually the same as VAULT_PATH.
TASK_MAXXING_REPO=/absolute/path/to/your-vault/08-Tasks

# Optional: log file the daemon writes to. Defaults to
# ~/Library/Logs/task-maxxing.log on macOS.
# TASK_MAXXING_LOG=/absolute/path/to/task-maxxing.log

# Optional: branch the daemon pushes to (default: main)
# TASK_MAXXING_BRANCH=main

# ---------------------------------------------------------------------------
# GitHub — W1 trigger + W2/W3 commit-back
# ---------------------------------------------------------------------------

# The GitHub user / org that owns the task-mirror repo n8n watches for
# Obsidian task pushes. This should be the git remote pointed at VAULT_PATH,
# whose push triggers W1.
GITHUB_REPO_OWNER=your-github-user

# The name of the task-mirror repo (no leading slash).
GITHUB_REPO_NAME=your-vault-tasks-repo

# Back-compat: scripts/install-workflows.sh will also accept a joined
# GITHUB_REPO="owner/repo" if you prefer the single-string form, but
# GITHUB_REPO_OWNER + GITHUB_REPO_NAME above are the canonical pair.
# GITHUB_REPO=${GITHUB_REPO_OWNER}/${GITHUB_REPO_NAME}

# OAuth token or fine-grained PAT with:
#   - contents: read + write  (W2/W3 commit markdown edits back)
#   - metadata: read          (githubTrigger webhook)
# Do NOT use your personal classic PAT here if you can avoid it.
GITHUB_TOKEN=gho_replace_me

# ---------------------------------------------------------------------------
# Notion — database mirror
# ---------------------------------------------------------------------------

# Internal integration token from https://www.notion.so/my-integrations
# Must start with `ntn_`. The integration must be shared with your tasks DB.
NOTION_TOKEN=ntn_replace_me

# The Notion database ID (with or without dashes). See notion/tasks-db-schema.md
# for the required schema.
NOTION_DATABASE_ID=00000000-0000-0000-0000-000000000000

# ---------------------------------------------------------------------------
# Morgen — native task mirror + calendar scheduling
# ---------------------------------------------------------------------------

# Morgen API key from https://app.morgen.so/settings/api
# Used as `Authorization: ApiKey <key>`. Rate limit: 300 pts / 15 min.
MORGEN_API_KEY=replace_me

# Alias read by workflows/install-workflows.sh (same value).
MORGEN_KEY=${MORGEN_API_KEY}

# ---------------------------------------------------------------------------
# n8n — workflow install target
# ---------------------------------------------------------------------------

# Your n8n public API key (Settings → API in the n8n UI).
N8N_API_KEY=replace_me

# Base URL of your n8n instance. Self-hosted or cloud, either works.
N8N_BASE_URL=https://your-tenant.app.n8n.cloud
